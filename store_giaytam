 @Status     VARCHAR(Max) = '',  
 @IsDLDate  TINYINT = 0,  
 @DateDLDateFrom DATETIME = '',  ----  
 @DateDLDateTo DATETIME = '' ----  
)   
AS   
SET NOCOUNT ON  
  
DECLARE  @SQLGenCol00 NVARCHAR(4000),  
   @SQLGenCol01 NVARCHAR(MAX),  
   @SQLGenCol02 NVARCHAR(4000),  
   @SQLGenCol03 NVARCHAR(4000),  
   @SQLGenCol04 NVARCHAR(4000),  
   @SQLCreTble NVARCHAR(4000),  
   @SQL00 NVARCHAR(4000),  
